# Порт сервера
PORT=3000

# На каком интерфейсе слушать. За reverse-proxy (Caddy/nginx) — 127.0.0.1
# HOST=127.0.0.1

# Куда складывать базу и фото (по умолчанию ./data)
# DATA_DIR=./data

# Часовой пояс — важно для смены "дня" в полночь по вашему времени
TZ=Europe/Moscow

# Максимум аккаунтов (после — регистрация закрывается)
MAX_USERS=4

# Код-приглашение для регистрации (если задан — требуется всегда)
# INVITE_CODE=secret123

# Подсчёт калорий и веса по фото через Claude API (необязательно).
# Без ключа всё работает, калории вводятся вручную.
# ANTHROPIC_API_KEY=sk-ant-...
# Модель для анализа фото. По умолчанию claude-opus-4-8 (точнее всего).
# Дешевле и быстрее: claude-haiku-4-5
# AI_MODEL=claude-opus-4-8
